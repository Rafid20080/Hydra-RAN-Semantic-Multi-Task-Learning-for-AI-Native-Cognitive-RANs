"""
Offline Pre-training for Hydra-RAN
IEEE TCCN Reproducibility Package
"""

import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
from tqdm import tqdm
import matplotlib.pyplot as plt
import warnings
warnings.filterwarnings('ignore')

from src.config import Config
from src.encoder import SharedSemanticEncoder
from src.fusion import TaskRelevanceGatedFusion
from src.smoother import TaskSensitivityWeightedSmoother
from src.multitask_heads import MultiTaskHeads


def generate_synthetic_data(num_samples, input_dim=64, num_modalities=4, sparsity=0.0):
    """Generate synthetic multi-modal data with optional sparsity."""
    X = np.random.randn(num_samples, num_modalities, input_dim)
    M = np.random.rand(num_samples, num_modalities, input_dim) > sparsity
    
    # Mask data
    X_masked = X * M.astype(np.float32)
    
    # Generate tasks
    # Target cell selection (7 classes)
    cell_targets = np.random.randint(0, 7, (num_samples,))
    
    # Resource demand (continuous)
    resource_targets = np.random.rand(num_samples, 1)
    
    # Beam selection (64 beams)
    beam_targets = np.random.randint(0, 64, (num_samples,))
    
    return X_masked, M.astype(np.float32), {
        'cell': cell_targets,
        'resource': resource_targets,
        'beam': beam_targets
    }


class OfflineTrainer:
    """Trainer for offline pre-training of Hydra-RAN."""
    
    def __init__(self, config):
        self.config = config
        self.device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
        
        # Initialize model components
        self.encoder = SharedSemanticEncoder(
            input_dim=config.DATASET.INPUT_DIMENSION,
            latent_dim=config.DATASET.LATENT_DIMENSION
        ).to(self.device)
        
        self.fusion = TaskRelevanceGatedFusion(
            latent_dim=config.DATASET.LATENT_DIMENSION,
            num_modalities=config.DATASET.NUM_MODALITIES
        ).to(self.device)
        
        self.smoother = TaskSensitivityWeightedSmoother(
            latent_dim=config.DATASET.LATENT_DIMENSION,
            beta=config.MODEL.BETA
        ).to(self.device)
        
        self.heads = MultiTaskHeads(
            latent_dim=config.DATASET.LATENT_DIMENSION,
            num_cells=config.DATASET.NUM_CELLS,
            num_beams=config.DATASET.NUM_BEAMS
        ).to(self.device)
        
        # Optimizer
        self.optimizer = optim.Adam(
            list(self.encoder.parameters()) +
            list(self.fusion.parameters()) +
            list(self.smoother.parameters()) +
            list(self.heads.parameters()),
            lr=config.TRAINING.LEARNING_RATE
        )
        
        # Loss functions
        self.cell_loss = nn.CrossEntropyLoss()
        self.resource_loss = nn.MSELoss()
        self.beam_loss = nn.CrossEntropyLoss()
    
    def train_epoch(self, X, M, targets):
        """Train for one epoch."""
        X = torch.FloatTensor(X).to(self.device)
        M = torch.FloatTensor(M).to(self.device)
        
        # Forward pass
        modalities = self.encoder(X.view(-1, self.config.DATASET.INPUT_DIMENSION))
        modalities = modalities.view(X.size(0), -1, self.config.DATASET.LATENT_DIMENSION)
        
        fused = self.fusion(modalities, M)
        smoothed = self.smoother(fused)
        
        outputs = self.heads(smoothed)
        
        # Compute losses
        loss_cell = self.cell_loss(outputs['cell'], torch.LongTensor(targets['cell']).to(self.device))
        loss_resource = self.resource_loss(outputs['resource'], torch.FloatTensor(targets['resource']).to(self.device))
        loss_beam = self.beam_loss(outputs['beam'], torch.LongTensor(targets['beam']).to(self.device))
        
        # Total loss with uncertainty weighting
        total_loss = loss_cell + loss_resource + loss_beam
        
        # Backward
        self.optimizer.zero_grad()
        total_loss.backward()
        self.optimizer.step()
        
        return {
            'total': total_loss.item(),
            'cell': loss_cell.item(),
            'resource': loss_resource.item(),
            'beam': loss_beam.item()
        }
    
    def train(self, num_epochs=200, verbose=True):
        """Run full training."""
        history = {'total': [], 'cell': [], 'resource': [], 'beam': []}
        
        for epoch in tqdm(range(num_epochs), disable=not verbose):
            # Generate data with sparsity
            X, M, targets = generate_synthetic_data(
                self.config.TRAINING.BATCH_SIZE,
                input_dim=self.config.DATASET.INPUT_DIMENSION,
                sparsity=0.0  # Full observations for pre-training
            )
            
            losses = self.train_epoch(X, M, targets)
            
            for k, v in losses.items():
                history[k].append(v)
            
            if verbose and epoch % 10 == 0:
                print(f"Epoch {epoch}: Total Loss = {losses['total']:.4f}")
        
        return history


def main():
    """Main execution function."""
    config = Config()
    config.initialize_random_seed()
    
    print("=" * 70)
    print("Hydra-RAN Offline Pre-training")
    print("=" * 70)
    
    # Initialize trainer
    trainer = OfflineTrainer(config)
    
    # Train
    history = trainer.train(
        num_epochs=config.TRAINING.NUM_EPOCHS,
        verbose=True
    )
    
    # Plot results
    fig, axes = plt.subplots(1, 3, figsize=(12, 4))
    
    axes[0].plot(history['cell'])
    axes[0].set_xlabel('Epoch')
    axes[0].set_ylabel('Cell Selection Loss')
    axes[0].set_title('Target Cell Selection')
    axes[0].grid(True, alpha=0.3)
    
    axes[1].plot(history['resource'])
    axes[1].set_xlabel('Epoch')
    axes[1].set_ylabel('Resource Demand Loss')
    axes[1].set_title('Resource Demand Estimation')
    axes[1].grid(True, alpha=0.3)
    
    axes[2].plot(history['beam'])
    axes[2].set_xlabel('Epoch')
    axes[2].set_ylabel('Beam Selection Loss')
    axes[2].set_title('Interference Mitigation')
    axes[2].grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.savefig('figures/offline_convergence.pdf', dpi=300, bbox_inches='tight')
    plt.show()
    
    print("\nPre-training complete!")
    print(f"Final Cell Loss: {history['cell'][-1]:.4f}")
    print(f"Final Resource Loss: {history['resource'][-1]:.4f}")
    print(f"Final Beam Loss: {history['beam'][-1]:.4f}")


if __name__ == "__main__":
    main()
